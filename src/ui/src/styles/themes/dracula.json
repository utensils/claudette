      "shadow-lg": "0 26px 54px -18px rgba(10, 8, 18, 0.90), 0 8px 16px -6px rgba(20, 18, 32, 0.62), 0 0 0 1px rgba(189, 147, 249, 0.10)",
      "shadow-card-hover": "0 18px 38px -14px rgba(10, 8, 18, 0.85), 0 4px 10px -2px rgba(20, 18, 32, 0.55), 0 0 0 1px rgba(255, 121, 198, 0.42), 0 0 30px rgba(189, 147, 249, 0.22)",
      "well-shadow": "inset 0 2px 10px rgba(6, 4, 12, 0.80), inset 0 -1px 0 rgba(248, 248, 242, 0.04), inset 0 0 0 1px rgba(189, 147, 249, 0.07)",
      "composer-ring": "inset 0 0 0 1px rgba(189, 147, 249, 0.22), inset 0 1px 0 rgba(248, 248, 242, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(255, 121, 198, 0.85), inset 0 1px 0 rgba(255, 220, 238, 0.22), 0 0 0 3px rgba(189, 147, 249, 0.20), 0 10px 30px -8px rgba(255, 121, 198, 0.35), 0 0 44px rgba(189, 147, 249, 0.12)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.58",
      "line-height-relaxed": "1.72",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.055em"
    },
    "radius": {
      "radius-sm": "5px",
      "radius-md": "9px",
      "radius-lg": "16px",
      "radius-pill": "999px",
      "border-radius": "9px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.2s ease",
      "transition-slow": "0.3s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.1s ease"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(189, 147, 249, 0.18)",
      "scrollbar-thumb-hover-bg": "rgba(255, 121, 198, 0.48)",
      "focus-ring": "0 0 0 1px rgba(255, 220, 238, 0.55), 0 0 0 3px rgba(255, 121, 198, 0.55), 0 6px 18px rgba(189, 147, 249, 0.28)",
      "chat-max-width": "880px",
      "turn-gap": "16px",
      "composer-min-height": "64px",
      "composer-padding-y": "14px",
      "canvas-padding-inline": "32px",
      "sidebar-item-padding-y": "6px"
    },
    "icon": {
      "icon-sm": "13px",
      "icon-md": "15px"
    },
    "control": {
      "control-height-md": "30px"
    },
    "component": {
      "menu-item-padding-x": "12px"
    }
  }
}
