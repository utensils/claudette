{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "linear",
    "name": "Linear",
    "author": "Claudette",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Modern product editorial \u2014 hushed indigo-black, a single violet signature, clean radii and quiet precision.",
    "stylesheet": "stylesheets/linear.css",
    "preview": {
      "background": "#0a0a14",
      "surface": "#16162a",
      "accent": "#7b6ef4",
      "text": "#e4e4ef"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#0a0a14",
      "sidebar-bg": "#0d0d1a",
      "sidebar-border": "#1d1d33",
      "panel-bg": "#10101e",
      "surface-bg": "#16162a",
      "sunken-bg": "#06060e",
      "text-primary": "#e4e4ef",
      "text-muted": "#b4b4c8",
      "text-dim": "#8585a0",
      "text-faint": "#585870",
      "text-separator": "#232340",
      "accent-primary": "#7b6ef4",
      "accent-primary-rgb": "123, 110, 244",
      "accent-dim": "#5e52c9",
      "accent-bg": "rgba(123, 110, 244, 0.08)",
      "accent-bg-strong": "rgba(123, 110, 244, 0.20)",
      "accent-glow": "0 0 1px rgba(230, 220, 255, 0.65), 0 0 10px rgba(123, 110, 244, 0.50), 0 0 28px rgba(123, 110, 244, 0.22), 0 0 60px rgba(123, 110, 244, 0.08)",
      "hover-bg": "rgba(228, 228, 239, 0.05)",
      "hover-bg-subtle": "rgba(228, 228, 239, 0.028)",
      "selected-bg": "rgba(123, 110, 244, 0.14)",
      "divider": "#1c1c30",
      "status-running": "#7b6ef4",
      "status-idle": "#8585a0",
      "status-stopped": "#ef6a78",
      "badge-done": "#56e1e9",
      "badge-plan": "#7b6ef4",
      "badge-ask": "#e8c97a",
      "diff-added-bg": "rgba(86, 225, 233, 0.10)",
      "diff-removed-bg": "rgba(239, 106, 120, 0.12)",
      "diff-added-text": "#7ce9ee",
      "diff-removed-text": "#ef8a94",
      "diff-hunk-header": "#56e1e9",
      "diff-line-number": "#585870",
      "chat-user-bg": "rgba(228, 228, 239, 0.025)",
      "chat-system-bg": "rgba(123, 110, 244, 0.055)",
      "chat-input-bg": "#08080f",
      "chat-header-bg": "#0d0d1a",
      "terminal-tab-bg": "#0d0d1a",
      "terminal-tab-active-bg": "#16162a",
      "terminal-bg": "#06060e",
      "terminal-fg": "#e4e4ef",
      "terminal-cursor": "#7b6ef4",
      "terminal-selection": "rgba(123, 110, 244, 0.28)",
      "toolbar-active": "rgba(123, 110, 244, 0.18)",
      "toolbar-active-text": "#a79cf8",
      "error-bg": "rgba(239, 106, 120, 0.10)",
      "error-border": "rgba(239, 106, 120, 0.38)",
      "error-hover": "rgba(239, 106, 120, 0.16)",
      "overlay-bg": "rgba(6, 4, 16, 0.68)",
      "overlay-bg-heavy": "rgba(6, 4, 16, 0.88)",
      "canvas-atmosphere": "radial-gradient(70% 45% at 82% -8%, rgba(123, 110, 244, 0.085), transparent 58%), radial-gradient(60% 40% at 18% 0%, rgba(86, 225, 233, 0.028), transparent 68%), radial-gradient(120% 80% at 50% 110%, rgba(6, 4, 16, 0.55), transparent 60%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 160'><filter id='p'><feTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.89  0 0 0 0 0.89  0 0 0 0 0.96  0 0 0 0.022 0'/></filter><rect width='100%25' height='100%25' filter='url(%23p)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(228, 228, 239, 0.05)",
      "rim-light-strong": "inset 0 1px 0 rgba(167, 156, 248, 0.12), inset 0 -1px 0 rgba(6, 4, 16, 0.55)",
      "selection-bg": "rgba(123, 110, 244, 0.34)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(6, 4, 16, 0.70), 0 0 0 1px rgba(123, 110, 244, 0.04)",
      "shadow-md": "0 10px 28px -12px rgba(6, 4, 16, 0.82), 0 2px 6px -2px rgba(12, 10, 28, 0.55), 0 0 0 1px rgba(123, 110, 244, 0.05)",
      "shadow-lg": "0 24px 52px -18px rgba(6, 4, 16, 0.92), 0 8px 16px -6px rgba(12, 10, 28, 0.62), 0 0 0 1px rgba(123, 110, 244, 0.09)",
      "shadow-card-hover": "0 16px 36px -14px rgba(6, 4, 16, 0.86), 0 4px 10px -2px rgba(12, 10, 28, 0.58), 0 0 0 1px rgba(123, 110, 244, 0.38), 0 0 28px rgba(123, 110, 244, 0.18)",
      "well-shadow": "inset 0 2px 10px rgba(3, 2, 10, 0.78), inset 0 -1px 0 rgba(228, 228, 239, 0.04), inset 0 0 0 1px rgba(123, 110, 244, 0.05)",
      "composer-ring": "inset 0 0 0 1px rgba(123, 110, 244, 0.20), inset 0 1px 0 rgba(228, 228, 239, 0.05)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(123, 110, 244, 0.82), inset 0 1px 0 rgba(230, 220, 255, 0.20), 0 0 0 3px rgba(123, 110, 244, 0.18), 0 10px 28px -8px rgba(123, 110, 244, 0.34), 0 0 40px rgba(123, 110, 244, 0.10)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.28",
      "line-height-normal": "1.56",
      "line-height-relaxed": "1.70",
      "letter-spacing-tight": "-0.015em",
      "letter-spacing-wide": "0.06em"
    },
    "radius": {
      "radius-sm": "3px",
      "radius-md": "6px",
      "radius-lg": "10px",
      "radius-pill": "999px",
      "border-radius": "6px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.14s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "transition-normal": "0.22s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "transition-slow": "0.34s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.1s ease"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(123, 110, 244, 0.14)",
      "scrollbar-thumb-hover-bg": "rgba(123, 110, 244, 0.42)",
      "focus-ring": "0 0 0 1px rgba(230, 220, 255, 0.50), 0 0 0 3px rgba(123, 110, 244, 0.55), 0 6px 18px rgba(123, 110, 244, 0.25)",
      "chat-max-width": "1080px",
      "turn-gap": "10px",
      "composer-min-height": "56px",
      "canvas-padding-inline": "28px",
      "sidebar-item-padding-y": "5px",
      "sidebar-item-gap": "1px"
    },
    "border": {
      "border-thin": "1px"
    },
    "icon": {
      "icon-sm": "13px",
      "icon-md": "15px"
    },
    "control": {
      "control-height-md": "30px",
      "control-height-lg": "36px"
    },
    "component": {
      "menu-item-padding-y": "6px",
      "menu-item-padding-x": "12px"
    }
  }
}
