{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "claude",
    "name": "Claude",
    "author": "Claudette",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Embers on parchment — Anthropic's signature terracotta glowing over warm paper-black.",
    "preview": {
      "background": "#15110e",
      "surface": "#221b15",
      "accent": "#d97757",
      "text": "#ede4d3"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",

      "app-bg": "#15110e",
      "sidebar-bg": "#1a1410",
      "sidebar-border": "#2a2118",
      "panel-bg": "#1d1711",
      "surface-bg": "#221b15",
      "sunken-bg": "#0f0c0a",

      "text-primary": "#ede4d3",
      "text-muted": "#c8bba6",
      "text-dim": "#9a8e7c",
      "text-faint": "#6e6558",
      "text-separator": "#3a3026",

      "accent-primary": "#d97757",
      "accent-primary-rgb": "217, 119, 87",
      "accent-dim": "#b75f42",
      "accent-bg": "rgba(217, 119, 87, 0.08)",
      "accent-bg-strong": "rgba(217, 119, 87, 0.18)",
      "accent-glow": "0 0 14px rgba(217, 119, 87, 0.45), 0 0 36px rgba(217, 119, 87, 0.18), 0 0 2px rgba(232, 178, 106, 0.55)",

      "hover-bg": "rgba(245, 237, 224, 0.06)",
      "hover-bg-subtle": "rgba(245, 237, 224, 0.035)",
      "selected-bg": "rgba(217, 119, 87, 0.12)",
      "divider": "#2c2319",

      "status-running": "#d97757",
      "status-idle": "#9a8e7c",
      "status-stopped": "#a84838",

      "badge-done": "#9bb068",
      "badge-plan": "#8a8cbf",
      "badge-ask": "#e8b26a",

      "diff-added-bg": "rgba(155, 176, 104, 0.12)",
      "diff-removed-bg": "rgba(168, 72, 56, 0.14)",
      "diff-added-text": "#b4c47d",
      "diff-removed-text": "#d47560",
      "diff-hunk-header": "#e8b26a",
      "diff-line-number": "#6e6558",

      "chat-user-bg": "rgba(245, 237, 224, 0.03)",
      "chat-system-bg": "rgba(217, 119, 87, 0.05)",
      "chat-input-bg": "#0f0c0a",
      "chat-header-bg": "#1a1410",

      "terminal-tab-bg": "#1a1410",
      "terminal-tab-active-bg": "#221b15",
      "terminal-bg": "#0c0907",
      "terminal-fg": "#ede4d3",
      "terminal-cursor": "#d97757",
      "terminal-selection": "rgba(217, 119, 87, 0.28)",

      "toolbar-active": "rgba(217, 119, 87, 0.16)",
      "toolbar-active-text": "#e89877",

      "error-bg": "rgba(168, 72, 56, 0.10)",
      "error-border": "rgba(168, 72, 56, 0.38)",
      "error-hover": "rgba(168, 72, 56, 0.16)",

      "overlay-bg": "rgba(15, 12, 10, 0.62)",
      "overlay-bg-heavy": "rgba(15, 12, 10, 0.82)",

      "canvas-atmosphere": "radial-gradient(140% 90% at 50% -10%, rgba(217, 119, 87, 0.06), transparent 55%), radial-gradient(100% 60% at 50% 0%, rgba(232, 178, 106, 0.03), transparent 70%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'><filter id='g'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.94  0 0 0 0 0.89  0 0 0 0 0.83  0 0 0 0.035 0'/></filter><rect width='100%25' height='100%25' filter='url(%23g)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(245, 237, 224, 0.06)",
      "rim-light-strong": "inset 0 1px 0 rgba(232, 178, 106, 0.14)",
      "selection-bg": "rgba(217, 119, 87, 0.32)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(15, 12, 10, 0.55)",
      "shadow-md": "0 8px 24px -10px rgba(26, 20, 16, 0.75), 0 2px 4px -2px rgba(26, 20, 16, 0.45)",
      "shadow-lg": "0 20px 44px -16px rgba(15, 12, 10, 0.85), 0 6px 12px -6px rgba(26, 20, 16, 0.55)",
      "shadow-card-hover": "0 14px 32px -12px rgba(15, 12, 10, 0.80), 0 0 0 1px rgba(217, 119, 87, 0.30), 0 0 20px rgba(217, 119, 87, 0.12)",
      "well-shadow": "inset 0 2px 8px rgba(8, 6, 4, 0.70), inset 0 -1px 0 rgba(245, 237, 224, 0.035)",
      "composer-ring": "inset 0 0 0 1px rgba(217, 119, 87, 0.18), inset 0 1px 0 rgba(245, 237, 224, 0.04)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(217, 119, 87, 0.70), 0 0 0 3px rgba(217, 119, 87, 0.14), 0 8px 24px -8px rgba(217, 119, 87, 0.30)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.55",
      "line-height-relaxed": "1.7",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "3px",
      "radius-md": "5px",
      "radius-lg": "10px",
      "radius-pill": "999px",
      "border-radius": "5px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.2s ease",
      "transition-slow": "0.3s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(245, 237, 224, 0.07)",
      "scrollbar-thumb-hover-bg": "rgba(217, 119, 87, 0.30)",
      "focus-ring": "0 0 0 2px rgba(217, 119, 87, 0.60), 0 4px 14px rgba(217, 119, 87, 0.22)"
    }
  }
}
