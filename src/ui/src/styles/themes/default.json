{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "default",
    "name": "Default",
    "author": "James Brink",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Warm chrome, dark terminal chat — Ristretto-inspired amber on rosewood.",
    "preview": {
      "background": "#2c2525",
      "surface": "#504646",
      "accent": "#f9cc6c",
      "text": "#f1e5e7"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",

      "app-bg": "#2c2525",
      "sidebar-bg": "#504646",
      "sidebar-border": "#6e6464",
      "panel-bg": "#3a3131",
      "surface-bg": "#453a3a",
      "sunken-bg": "#241e1e",

      "text-primary": "#f1e5e7",
      "text-muted": "#d0c4c6",
      "text-dim": "#b0a4a6",
      "text-faint": "#907e80",
      "text-separator": "#7a6e70",

      "accent-primary": "#f9cc6c",
      "accent-primary-rgb": "249, 204, 108",
      "accent-dim": "#d4a84a",
      "accent-bg": "rgba(249, 204, 108, 0.10)",
      "accent-bg-strong": "rgba(249, 204, 108, 0.20)",
      "accent-glow": "0 0 12px rgba(249, 204, 108, 0.30)",

      "hover-bg": "rgba(255, 255, 255, 0.10)",
      "hover-bg-subtle": "rgba(255, 255, 255, 0.06)",
      "selected-bg": "rgba(249, 204, 108, 0.14)",
      "divider": "#6e6464",

      "status-running": "#f9cc6c",
      "status-idle": "#d0c4c6",
      "status-stopped": "#fd6883",

      "badge-done": "#85dacc",
      "badge-plan": "#a8a9eb",
      "badge-ask": "#f38d70",

      "diff-added-bg": "rgba(173, 218, 120, 0.14)",
      "diff-removed-bg": "rgba(253, 104, 131, 0.14)",
      "diff-added-text": "#adda78",
      "diff-removed-text": "#fd6883",
      "diff-hunk-header": "#85dacc",
      "diff-line-number": "#907e80",

      "chat-user-bg": "rgba(255, 240, 235, 0.04)",
      "chat-system-bg": "rgba(224, 175, 104, 0.06)",
      "chat-input-bg": "#241e1e",
      "chat-header-bg": "#24283b",

      "terminal-tab-bg": "#504646",
      "terminal-tab-active-bg": "#605454",
      "terminal-bg": "#1e1818",
      "terminal-fg": "#f1e5e7",
      "terminal-cursor": "#f9cc6c",
      "terminal-selection": "rgba(249, 204, 108, 0.25)",

      "toolbar-active": "rgba(249, 204, 108, 0.18)",
      "toolbar-active-text": "#f9cc6c",

      "error-bg": "rgba(253, 104, 131, 0.10)",
      "error-border": "rgba(253, 104, 131, 0.35)",
      "error-hover": "rgba(253, 104, 131, 0.15)",

      "overlay-bg": "rgba(0, 0, 0, 0.55)",
      "overlay-bg-heavy": "rgba(0, 0, 0, 0.75)",

      "canvas-atmosphere": "radial-gradient(120% 80% at 50% 0%, rgba(255, 255, 255, 0.03), transparent 60%)",
      "rim-light": "rgba(255, 255, 255, 0.04)",
      "rim-light-strong": "rgba(255, 255, 255, 0.08)",
      "selection-bg": "rgba(249, 204, 108, 0.30)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(0, 0, 0, 0.35)",
      "shadow-md": "0 4px 12px rgba(0, 0, 0, 0.45)",
      "shadow-lg": "0 8px 24px rgba(0, 0, 0, 0.55)",
      "shadow-card-hover": "0 8px 24px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(249, 204, 108, 0.20)",
      "well-shadow": "inset 0 2px 6px rgba(0, 0, 0, 0.45)",
      "composer-ring": "inset 0 0 0 1px rgba(255, 255, 255, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(249, 204, 108, 0.45)"
    },
    "typography": {
      "font-sans": "\"Instrument Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
      "font-mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", \"Cascadia Code\", monospace",
      "font-display": "\"Instrument Serif\", \"Iowan Old Style\", Georgia, serif",
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.55",
      "line-height-relaxed": "1.7",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "4px",
      "radius-md": "8px",
      "radius-lg": "14px",
      "radius-pill": "999px",
      "border-radius": "8px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.2s ease",
      "transition-slow": "0.3s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "sidebar-width": "260px",
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(255, 255, 255, 0.08)",
      "scrollbar-thumb-hover-bg": "rgba(249, 204, 108, 0.25)",
      "focus-ring": "0 0 0 2px rgba(249, 204, 108, 0.5)"
    }
  }
}
