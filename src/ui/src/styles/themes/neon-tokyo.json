{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "neon-tokyo",
    "name": "Neon Tokyo",
    "author": "James Brink",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Synth rain on wet asphalt — 2049-era magenta and cyan electricity across chrome-black substrates.",
    "preview": {
      "background": "#0a0612",
      "surface": "#17112a",
      "accent": "#ff2e88",
      "text": "#f4ebff"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",

      "app-bg": "#0a0612",
      "sidebar-bg": "#0d0a1a",
      "sidebar-border": "#2a1b3d",
      "panel-bg": "#120d22",
      "surface-bg": "#17112a",
      "sunken-bg": "#050308",

      "text-primary": "#f4ebff",
      "text-muted": "#c8b8e0",
      "text-dim": "#9a8ab8",
      "text-faint": "#6b5d85",
      "text-separator": "#3a2d55",

      "accent-primary": "#ff2e88",
      "accent-primary-rgb": "255, 46, 136",
      "accent-dim": "#c91f6a",
      "accent-bg": "rgba(255, 46, 136, 0.12)",
      "accent-bg-strong": "rgba(255, 46, 136, 0.24)",
      "accent-glow": "0 0 20px rgba(255, 46, 136, 0.55), 0 0 40px rgba(255, 46, 136, 0.28), 0 0 80px rgba(255, 46, 136, 0.12)",

      "hover-bg": "rgba(255, 46, 136, 0.10)",
      "hover-bg-subtle": "rgba(0, 229, 255, 0.05)",
      "selected-bg": "rgba(255, 46, 136, 0.18)",
      "divider": "#2a1b3d",

      "status-running": "#ff2e88",
      "status-idle": "#9a8ab8",
      "status-stopped": "#c6ff00",

      "badge-done": "#00e5ff",
      "badge-plan": "#b388ff",
      "badge-ask": "#ffb300",

      "diff-added-bg": "rgba(64, 255, 218, 0.14)",
      "diff-removed-bg": "rgba(255, 46, 136, 0.14)",
      "diff-added-text": "#5effd6",
      "diff-removed-text": "#ff4d9a",
      "diff-hunk-header": "#00e5ff",
      "diff-line-number": "#6b5d85",

      "chat-user-bg": "rgba(0, 229, 255, 0.04)",
      "chat-system-bg": "rgba(255, 46, 136, 0.06)",
      "chat-input-bg": "#050308",
      "chat-header-bg": "#0d0a1a",

      "terminal-tab-bg": "#0d0a1a",
      "terminal-tab-active-bg": "#1a1235",
      "terminal-bg": "#030107",
      "terminal-fg": "#f4ebff",
      "terminal-cursor": "#ff2e88",
      "terminal-selection": "rgba(255, 46, 136, 0.30)",

      "toolbar-active": "rgba(255, 46, 136, 0.20)",
      "toolbar-active-text": "#ff5ca0",

      "error-bg": "rgba(255, 23, 104, 0.12)",
      "error-border": "rgba(255, 23, 104, 0.45)",
      "error-hover": "rgba(255, 23, 104, 0.18)",

      "overlay-bg": "rgba(5, 3, 12, 0.70)",
      "overlay-bg-heavy": "rgba(5, 3, 12, 0.88)",

      "canvas-atmosphere": "repeating-linear-gradient(0deg, rgba(0, 229, 255, 0.020) 0 1px, transparent 1px 3px), radial-gradient(120% 80% at 85% 0%, rgba(255, 46, 136, 0.14), transparent 55%), radial-gradient(100% 70% at 15% 100%, rgba(0, 229, 255, 0.11), transparent 60%), linear-gradient(180deg, rgba(179, 136, 255, 0.05), transparent 40%)",
      "rim-light": "inset 0 1px 0 rgba(255, 46, 136, 0.18)",
      "rim-light-strong": "inset 0 1px 0 rgba(0, 229, 255, 0.22)",
      "selection-bg": "rgba(255, 46, 136, 0.38)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(0, 0, 0, 0.75), 0 0 0 1px rgba(179, 136, 255, 0.08)",
      "shadow-md": "0 6px 20px rgba(0, 0, 0, 0.80), 0 0 1px rgba(255, 46, 136, 0.18), 0 0 12px rgba(255, 46, 136, 0.06)",
      "shadow-lg": "0 18px 48px rgba(0, 0, 0, 0.88), 0 0 2px rgba(179, 136, 255, 0.25), 0 0 32px rgba(0, 229, 255, 0.08)",
      "shadow-card-hover": "0 10px 30px rgba(0, 0, 0, 0.70), 0 0 0 1px rgba(255, 46, 136, 0.60), 0 0 28px rgba(255, 46, 136, 0.35), 0 0 56px rgba(0, 229, 255, 0.12)",
      "well-shadow": "inset 0 2px 12px rgba(0, 0, 0, 0.85), inset 0 0 0 1px rgba(255, 46, 136, 0.14), inset 0 -1px 0 rgba(0, 229, 255, 0.10)",
      "composer-ring": "inset 0 0 0 1px rgba(255, 46, 136, 0.28), inset 0 0 0 2px rgba(0, 229, 255, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(255, 46, 136, 0.95), inset 0 0 0 2px rgba(0, 229, 255, 0.30), 0 0 28px rgba(255, 46, 136, 0.55), 0 0 56px rgba(255, 46, 136, 0.18)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.55",
      "line-height-relaxed": "1.7",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "0px",
      "radius-md": "2px",
      "radius-lg": "4px",
      "radius-pill": "999px",
      "border-radius": "2px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.2s ease",
      "transition-slow": "0.3s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(179, 136, 255, 0.14)",
      "scrollbar-thumb-hover-bg": "rgba(255, 46, 136, 0.40)",
      "focus-ring": "0 0 0 1px rgba(255, 46, 136, 0.90), 0 0 0 3px rgba(0, 229, 255, 0.25), 0 0 18px rgba(255, 46, 136, 0.45), 0 0 36px rgba(255, 46, 136, 0.18)"
    }
  }
}
