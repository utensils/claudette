---
import { Image } from 'astro:assets';
import dashboard from '../assets/screenshots/dashboard.png';
import agent from '../assets/screenshots/agent.png';

const shots = [
  {
    src: dashboard,
    alt: 'Claudette dashboard with workspace metrics, repo leaderboard, and activity heatmap',
    title: 'Your mission control',
    desc: 'Metrics, active workspaces, and analytics at a glance.',
  },
  {
    src: agent,
    alt: 'Claudette agent view with an active Claude Code session and an insight callout',
    title: 'Agents at work',
    desc: 'A dedicated Claude Code session per workspace, with full conversation history.',
  },
];
---

<section class="screenshots-section">
  <h2>See it in action</h2>
  <p class="section-subtitle">A beautiful native desktop app — fast, focused, and built for parallel work.</p>
  <div class="screenshots-grid">
    {shots.map((s) => (
      <figure class="screenshot">
        <Image src={s.src} alt={s.alt} loading="lazy" />
        <figcaption>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
