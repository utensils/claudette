---
import { Image } from 'astro:assets';
import dashboard from '../assets/screenshots/dashboard.png';
---

<section class="hero-v2">
  <div class="hero-inner">
    <div class="hero-eyebrow">
      <span class="pulse-dot"></span>
      Claude's missing better half
    </div>
    <h1>The open-source desktop companion <span class="accent">for Claude Code.</span></h1>
    <p class="tagline">
      Run agents in parallel across git worktrees, watch token usage in real time, and drive remote sessions over an encrypted connection — all from one focused desktop app.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="https://github.com/utensils/Claudette/releases">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
      <a class="btn btn-ghost" href="https://github.com/utensils/Claudette">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
        View on GitHub
      </a>
    </div>
    <div class="platform-badges">
      <span class="pb">macOS</span>
      <span class="pb">Linux</span>
      <span class="pb">Windows</span>
    </div>
  </div>

  <figure class="hero-shot" aria-label="Claudette dashboard with workspace metrics and live activity">
    <div class="shot-titlebar">
      <span class="traffic r"></span><span class="traffic y"></span><span class="traffic g"></span>
      <span class="title">claudette — dashboard</span>
    </div>
    <div class="shot-body">
      <Image src={dashboard} alt="Claudette dashboard with workspace metrics, repo leaderboard, and activity heatmap" loading="eager" />
    </div>
  </figure>
</section>
