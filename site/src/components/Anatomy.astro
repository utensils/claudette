---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

/*
 * Icons + colors here mirror the desktop app 1:1:
 *   - Session-state icons match `src/ui/src/components/shared/SessionStatusIcon.tsx`
 *     (Lucide: LoaderCircle, CircleCheck, CircleQuestionMark, CircleAlert,
 *     CircleStop, CircleDashed) and the matching `--badge-*` / `--status-*`
 *     tokens defined in the running theme.
 *   - PR-state icons match `src/ui/src/components/right-sidebar/PrStatusBanner.tsx`
 *     (Lucide: GitPullRequestArrow for ready/ci-pending/ci-failed/open,
 *     GitPullRequestDraft, GitMerge, GitPullRequestClosed).
 */

// Animation flags mirror the running app's Sidebar.module.css:
//   - Running: LoaderCircle spins (`.spinner` in SessionStatusIcon.module.css)
//   - Done / Plan / Ask: pulse via opacity 1 → 0.4 → 1 every 2s
//     (`.badgeDone / .badgePlan / .badgeAsk` use `pulse-badge` keyframes)
const sessionStates = [
  {
    label: 'Running — agent is producing tokens',
    color: 'var(--accent-primary)',
    spin: true,
    paths: '<path d="M21 12a9 9 0 1 1-6.219-8.56"/>',
  },
  {
    label: 'Done — agent finished, work ready to review',
    color: 'var(--badge-done)',
    pulse: true,
    paths: '<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    label: 'Ask — agent is waiting on you to answer',
    color: 'var(--badge-ask)',
    pulse: true,
    paths: '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>',
  },
  {
    label: 'Plan — running in plan mode (read-only)',
    color: 'var(--badge-plan)',
    pulse: true,
    paths: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
  },
  {
    label: 'Stopped — user stopped or session errored',
    color: 'var(--status-stopped)',
    paths: '<circle cx="12" cy="12" r="10"/><rect x="9" y="9" width="6" height="6" rx="1"/>',
  },
  {
    label: 'Idle — session exists but inactive',
    color: 'var(--text-dim)',
    // Lucide CircleDashed: 8 short arcs around an invisible circle.
    paths: '<path d="M10.1 2.182a10 10 0 0 1 3.8 0"/><path d="M13.9 21.818a10 10 0 0 1-3.8 0"/><path d="M17.609 3.721a10 10 0 0 1 2.69 2.7"/><path d="M2.182 13.9a10 10 0 0 1 0-3.8"/><path d="M20.279 17.609a10 10 0 0 1-2.7 2.69"/><path d="M21.818 10.1a10 10 0 0 1 0 3.8"/><path d="M3.721 6.391a10 10 0 0 1 2.7-2.69"/><path d="M6.391 20.279a10 10 0 0 1-2.69-2.7"/>',
  },
];

// Lucide GitPullRequestArrow: source circle (top-left) + branch line down,
// horizontal-then-down stem on the right side, an arrow head pointing left,
// and the target circle in the lower-right. Re-used for Open/CI states.
const PR_ARROW = '<circle cx="5" cy="6" r="3"/><path d="M5 9v12"/><circle cx="19" cy="18" r="3"/><path d="m15 9-3-3 3-3"/><path d="M12 6h5a2 2 0 0 1 2 2v7"/>';

const prStates = [
  { label: 'Open / Ready', color: 'var(--badge-done)', paths: PR_ARROW },
  { label: 'CI running', color: 'var(--badge-ask)', paths: PR_ARROW },
  { label: 'CI failed', color: 'var(--status-stopped)', paths: PR_ARROW },
  {
    label: 'Draft',
    color: 'var(--text-dim)',
    // Lucide GitPullRequestDraft: source + target circles, two short marks
    // on the right side standing in for the dashed branch.
    paths: '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M18 6V5"/><path d="M18 11v-1"/><line x1="6" x2="6" y1="9" y2="21"/>',
  },
  {
    label: 'Merged',
    color: 'var(--badge-plan)',
    paths: '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
  },
  {
    label: 'Closed',
    color: 'var(--text-dim)',
    // Lucide GitPullRequestClosed: source + target circles, an X over the
    // upper branch, and a short connector down to the target.
    paths: '<circle cx="6" cy="6" r="3"/><path d="M6 9v12"/><path d="m21 3-6 6"/><path d="m21 9-6-6"/><path d="M18 11.5V15"/><circle cx="18" cy="18" r="3"/>',
  },
];
---

<section class="anatomy" aria-label="Anatomy of a Claudette window">
  <div class="anatomy-inner">
    <div class="anatomy-text">
      <h2>Anatomy of a session.</h2>
      <p>One workspace, one agent, one chat. The sidebar tracks every parallel session by SCM status; the header shows your context budget; the composer drives the model.</p>

      <div class="legend-group">
        <p class="legend-label">Session state</p>
        <ul class="legend">
          {sessionStates.map((s) => {
            const cls = ['status-icon', s.spin && 'spin', s.pulse && 'pulse'].filter(Boolean).join(' ');
            return (
              <li>
                <span class={cls} style={`color: ${s.color}`}>
                  <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.paths} />
                </span>
                {s.label}
              </li>
            );
          })}
        </ul>
      </div>

      <div class="legend-group">
        <p class="legend-label">PR state</p>
        <ul class="legend">
          {prStates.map((s) => (
            <li>
              <span class="status-icon" style={`color: ${s.color}`}>
                <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.paths} />
              </span>
              {s.label}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <figure class="app-preview" aria-label="A real Claudette agent session">
      <video src={base + 'videos/parallel-agents.webm'} autoplay loop muted playsinline class="demo-video" />
    </figure>
  </div>
</section>
