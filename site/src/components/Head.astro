---
import Default from '@astrojs/starlight/components/Head.astro';

const siteUrl = 'https://utensils.github.io';
const base    = '/claudette';
const ogImage = `${siteUrl}${base}/og-image.png`;
---

<Default {...Astro.props}><slot /></Default>

<!-- og:image and twitter:image — not emitted by Starlight's default Head -->
<meta property="og:image"      content={ogImage} />
<meta property="og:image:alt"  content="Claudette dashboard — parallel Claude Code agents at a glance" />
<meta name="twitter:image"     content={ogImage} />
<meta name="twitter:image:alt" content="Claudette dashboard — parallel Claude Code agents at a glance" />
