---
const steps = [
  {
    num: 1,
    title: 'Install toolchain',
    desc: 'Rust, Bun, and the Tauri CLI. Full guide in the docs.',
  },
  {
    num: 2,
    title: 'Clone & build',
    descHtml: '<code>git clone</code> and <code>cargo tauri dev</code> — a native binary for your OS.',
  },
  {
    num: 3,
    title: 'Open a workspace',
    desc: 'Point at any git repo. Claudette spawns a worktree and you\'re in.',
  },
];
---

<section class="howto-slim">
  <div class="howto-slim-inner">
    <h2>Building from source?</h2>
    <p>Most people just download. If you want to hack on it, three commands gets you there.</p>
    <div class="howto-row">
      {steps.map((s) => (
        <div class="howto-step">
          <div class="num">{s.num}</div>
          <h4>{s.title}</h4>
          {s.descHtml ? <p set:html={s.descHtml} /> : <p>{s.desc}</p>}
        </div>
      ))}
    </div>
    <a class="howto-link" href="/claudette/getting-started/installation/">Read the install guide</a>
  </div>
</section>
