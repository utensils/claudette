---
const values = [
  {
    title: 'Local-first',
    desc: 'Your data stays on your machine',
    icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
  {
    title: 'Open source',
    desc: 'MIT licensed on GitHub',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    title: 'No telemetry',
    desc: 'No accounts, no tracking',
    icon: '<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>',
  },
  {
    title: 'Internationalized',
    desc: 'UI translated for global users',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  },
  {
    title: 'Built with Tauri 2',
    desc: 'Rust backend, React frontend',
    icon: '<path d="M12 2L2 7l10 5 10-5-10-5z"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  },
];
---

<section class="values" aria-label="What we stand for">
  <div class="values-grid">
    {values.map((v) => (
      <div class="value">
        <span class="vi">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={v.icon} />
        </span>
        <span><strong>{v.title}</strong>{v.desc}</span>
      </div>
    ))}
  </div>
</section>
