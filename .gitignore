# Rust / Cargo
/target
**/target/
debug/
**/*.rs.bk
*.pdb
**/mutants.out*/

# Coverage
lcov.info
*.profraw
*.profdata

# Node / Frontend
node_modules/
src/ui/dist/
site/dist/
site/.astro/

# Tauri generated
src-tauri/gen/
# Generated bundle icons — regenerated from src-tauri/icons/icon.png by build.rs
# (see issue #516). Only icon.png is tracked.
src-tauri/icons/*.png
!src-tauri/icons/icon.png
src-tauri/icons/*.icns
src-tauri/icons/*.ico
src-tauri/icons/android/
src-tauri/icons/ios/

# Nix
result
result-*
.direnv/

# macOS
.DS_Store
*.dSYM/

# Linux
*~
.directory

# VS Code
.vscode/

# Neovim
*.swp
*.swo
tags

# JetBrains
#.idea/

# Conductor
.context/

# Claude Code
.claude/worktrees/
.claude/scheduled_tasks.lock
# Per-session scratch dir for Claude Code agents — long-running build
# logs, monitor output, debug-eval transcripts. Never committed.
/.claude-tmp/

# OpenAI Codex (skills exported from .claude/skills/ via codex-export)
.agents/

# Superpowers brainstorm
.superpowers/

# Documentation
/docs

# Claudette devshell runtime state (aws-win-* sidecars, etc.)
/.claudette/

# CLI sidecars staged for `tauri build`'s `bundle.externalBin` to
# consume. Built per-target by CI (and by scripts/stage-cli-sidecar.sh
# locally) before each bundle; never checked in.
/src-tauri/binaries/
