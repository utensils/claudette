{
  "productName": "Claudette",
  "identifier": "com.claudette.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src/ui/dist",
    "watchIgnored": ["binaries/**"]
  },
  "app": {
    "windows": [
      {
        "title": "Claudette",
        "width": 1200,
        "height": 800,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main application permissions",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:default",
            "shell:default",
            "clipboard-manager:allow-write-text",
            "clipboard-manager:allow-read-text"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/logo.png"
    ],
    "externalBin": [
      "binaries/claudette-server"
    ]
  }
}
