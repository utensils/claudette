{
  "productName": "Claudette",
  "identifier": "com.claudette.app",
  "build": {
    "beforeDevCommand": { "script": "bun run dev", "cwd": "../src/ui" },
    "beforeBuildCommand": { "script": "bun run build", "cwd": "../src/ui" },
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claudette",
        "width": 1200,
        "height": 800,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main application permissions",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:default",
            "shell:default",
            "clipboard-manager:allow-write-text",
            "clipboard-manager:allow-read-text",
            "updater:default",
            "process:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "../assets/logo.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1NkQwQUJEQ0REREVDOUIKUldTYjdOM052UXB0SmZMdFNVRnhXQmJMTitTaGtUZjdjcWNQWmFsR0JJUmxVYTV6STVxN0F3TVUK",
      "endpoints": [
        "https://github.com/utensils/Claudette/releases/latest/download/latest.json"
      ]
    }
  }
}
