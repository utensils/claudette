{
  "identifier": "default",
  "description": "Default capability set for Claudette",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claudette-server",
          "sidecar": true
        }
      ]
    }
  ]
}
